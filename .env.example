# Configurações do Ambiente - PENOMATO MVP

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_NAME=penomato_mvp
DB_USER=root
DB_PASSWORD=

# Aplicação
APP_NAME="Penomato MVP"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/penomato_mvp

# Segurança
APP_KEY=base64:gerar_uma_chave_unica_aqui
SESSION_DRIVER=file
